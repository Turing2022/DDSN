class LDR(nn.Module):
    def __init__(self, inp_channels=3, out_channels=3, dim=24, base_dilation_rates=[1, 3, 5], kernel_size=3):
        super(LDR, self).__init__()
        self.input_conv = nn.Conv2d(inp_channels, dim, kernel_size=1, bias=False)
        self.conv_layers = nn.ModuleList([
            nn.Conv2d(dim, dim, kernel_size=kernel_size, padding=rate, dilation=rate, bias=False, groups=dim)
            for rate in base_dilation_rates
        ])
        self.combine_weights = nn.Parameter(torch.randn(len(base_dilation_rates)), requires_grad=True)
        self.output_conv = nn.Conv2d(dim, out_channels, kernel_size=1, bias=False)

    def forward(self, x):
        x = self.input_conv(x)
        conv_outputs = torch.stack([conv(x) for conv in self.conv_layers], dim=2)
        combine_weights = self.combine_weights.softmax(dim=0).view(1, 1, -1, 1, 1)
        combined_output = torch.sum(conv_outputs * combine_weights, dim=2)
        x = self.output_conv(combined_output)
        return x


class NoiseEstimator(nn.Module):
    def __init__(self, local_dilation_rates, global_dilation_rates, inp_channels=3, out_channels=3, dim=24):
        super(NoiseEstimator, self).__init__()
        self.noise_est_local = LDR(inp_channels=inp_channels, out_channels=dim, dim=dim, kernel_size=3,
                                   base_dilation_rates=local_dilation_rates)
        self.noise_est_global = LDR(inp_channels=inp_channels, out_channels=dim, dim=dim, kernel_size=3,
                                    base_dilation_rates=global_dilation_rates)
        self.out_conv = nn.Conv2d(in_channels=dim * 2, out_channels=out_channels, kernel_size=1)

    def forward(self, x):
        noise_local = self.noise_est_local(x)
        noise_global = self.noise_est_global(x)
        noise_map = torch.cat([noise_local, noise_global], dim=1)
        output = self.out_conv(noise_map)
        return output


# ==========================================
# 3. SNN 核心组件: IAT-Neuron
# ==========================================
class SurrogateBP(torch.autograd.Function):
    @staticmethod
    def forward(ctx, input):
        ctx.save_for_backward(input)
        return (input > 0).float()

    @staticmethod
    def backward(ctx, grad_output):
        input, = ctx.saved_tensors
        return grad_output / (1 + 2.0 * input.abs()) ** 2


class BipolarNeuron(nn.Module):
    """
    Illumination-Adaptive Ternary Spiking Neuron (IAT-Neuron)
    支持基于幅度谱的动态阈值调制 (Amplitude-Guided Threshold Modulation)
    """

    def __init__(self, threshold=0.5, learnable=True):
        super().__init__()
        if learnable:
            self.threshold = nn.Parameter(torch.tensor(threshold))
        else:
            self.register_buffer('threshold', torch.tensor(threshold))
        self.act = SurrogateBP.apply
        self.alpha = nn.Parameter(torch.tensor(1.0))

    def forward(self, x, gate=None):
        """
        x: Membrane potential
        gate: Dynamic threshold delta (from Frequency Amplitude)
        """
        base_thresh = self.threshold.abs()

        # === IAT 核心机制 ===
        if gate is not None:
            # V_th = Base + Delta
            thresh = base_thresh + gate
            # 关键：安全截断，防止阈值 < 0 或过大
            # 范围 [0.1, 1.0] 覆盖正态分布关键区间
            thresh = torch.clamp(thresh, min=0.1, max=1.0)
        else:
            thresh = base_thresh

        # 三极判断: |x| > thresh
        pos = self.act((x - thresh) * self.alpha)
        neg = self.act((-x - thresh) * self.alpha)
        return pos - neg


