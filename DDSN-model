# 4. SpikingMSDeformableAttention (升级版: 含 SGA & IAT)
# ==========================================
def shift_max(x, dim=-1):
    # ShiftMax 替代 Softmax
    x_max = x.max(dim=dim, keepdim=True)[0]
    x_stabilized = x - x_max
    attn_weights = torch.pow(2.0, x_stabilized)
    out = attn_weights / (attn_weights.sum(dim=dim, keepdim=True) + 1e-6)
    return out


class SpikingMSDeformableAttention(nn.Module):
    def __init__(self, dim, num_heads, kernel_size, dilation=1, offset_range_factor=1.0, stride=1, no_off=False,
                 proj_drop=0.0, T=4):
        super().__init__()
        self.dim = dim
        self.num_heads = num_heads
        self.T = T
        self.head_dim = dim // num_heads
        self.kernel_size = kernel_size
        self.dilation = dilation
        self.offset_range_factor = offset_range_factor
        self.no_off = no_off
        self.scale = self.head_dim ** -0.5

        self.n_groups = num_heads
        self.n_group_channels = dim // num_heads

        self.ldr = NoiseEstimator([1, 2, 3], [5, 7, 9], inp_channels=dim, out_channels=dim, dim=dim // 8)

        kk = kernel_size
        pad_size = kk // 2

        # === SGA: Phase-Guided Offset Predictor ===
        # 接收 Query (C) + Phase (C) -> 2C
        self.conv_offset = nn.Sequential(
            nn.Conv2d(self.n_group_channels * 2, self.n_group_channels,
                      kk, stride, pad_size, groups=self.n_group_channels),
            LayerNorm2d(self.n_group_channels),
            nn.GELU(),
            nn.Conv2d(self.n_group_channels, 2, 1, 1, 0, bias=False)
        )
        if self.no_off:
            for m in self.conv_offset.parameters(): m.requires_grad_(False)

        # === SGA: Phase Refinement ===
        # DW-Conv 平滑相位图，去伪影
        self.phase_refine = nn.Sequential(
            nn.Conv2d(dim, dim, 3, padding=1, groups=dim),
            LayerNorm2d(dim),
            nn.GELU()
        )

        # === IAT: Amplitude-Guided Threshold Predictor ===
        # Tanh 允许正负调节 (-1 ~ 1)
        self.amp_to_thresh = nn.Sequential(
            nn.Conv2d(dim, dim, 1),
            nn.Tanh()
        )

        self.proj_q = nn.Conv2d(dim, dim, 1)
        self.proj_k = nn.Conv2d(dim, dim, 1)
        self.proj_v = nn.Conv2d(dim, dim, 1)
        self.proj_out = nn.Conv2d(dim, dim, 1)
        self.proj_drop = nn.Dropout(proj_drop)

        # 动态神经元
        self.q_lif = BipolarNeuron(threshold=0.5, learnable=True)
        self.k_lif = BipolarNeuron(threshold=0.5, learnable=True)
        self.v_lif = BipolarNeuron(threshold=0.5, learnable=True)
        self.attn_lif = BipolarNeuron(threshold=0.5, learnable=True)

        self.rpb_h1 = nn.Parameter(torch.zeros(num_heads // 3, kernel_size ** 2))
        self.rpb_h2 = nn.Parameter(torch.zeros(num_heads // 3, kernel_size ** 2))
        self.rpb_h3 = nn.Parameter(torch.zeros(num_heads // 3, (kernel_size + 2) ** 2))
        trunc_normal_(self.rpb_h1, std=0.02)
        trunc_normal_(self.rpb_h2, std=0.02)
        trunc_normal_(self.rpb_h3, std=0.02)
        self.rpe_table = nn.Conv2d(dim, dim, 3, 1, 1, groups=dim)

    def _get_ref_points(self, H, W, B, dtype, device):
        y = torch.linspace(0.5, H - 0.5, H, dtype=dtype, device=device)
        x = torch.linspace(0.5, W - 0.5, W, dtype=dtype, device=device)
        ref_y, ref_x = torch.meshgrid(y, x, indexing='ij')
        ref = torch.stack((ref_y, ref_x), -1)
        ref[..., 1].div_(W - 1.0).mul_(2.0).sub_(1.0)
        ref[..., 0].div_(H - 1.0).mul_(2.0).sub_(1.0)
        return ref[None, ...].expand(B * self.n_groups, -1, -1, -1)

    def _spiking_sliding_window_attn(self, q, k, v, kernel_size, dilation, rpb, thresh_gate=None):
        B, Heads, H, W, C = q.shape
        pad = (kernel_size // 2) * dilation

        k_in = k.permute(0, 1, 4, 2, 3).reshape(B * Heads, C, H, W)
        v_in = v.permute(0, 1, 4, 2, 3).reshape(B * Heads, C, H, W)
        k_wins = F.unfold(k_in, kernel_size=kernel_size, padding=pad, dilation=dilation)
        v_wins = F.unfold(v_in, kernel_size=kernel_size, padding=pad, dilation=dilation)
        k_wins = k_wins.view(B, Heads, C, -1, H, W).permute(0, 1, 4, 5, 2, 3)
        v_wins = v_wins.view(B, Heads, C, -1, H, W).permute(0, 1, 4, 5, 3, 2)

        q_ex = q.unsqueeze(-1)  # [B, Heads, H, W, C, 1]

        q_ex_seq = q_ex.unsqueeze(1).repeat(1, self.T, 1, 1, 1, 1, 1)
        k_wins_seq = k_wins.unsqueeze(1).repeat(1, self.T, 1, 1, 1, 1, 1)
        v_wins_seq = v_wins.unsqueeze(1).repeat(1, self.T, 1, 1, 1, 1, 1)

        # === IAT 动态阈值注入 ===
        gate_q = None
        if thresh_gate is not None:
            # thresh_gate: [B, Heads, H, W, C]
            # 扩展到时间维度: [B, 1, Heads, H, W, C, 1] 以广播到 q_ex_seq
            gate_q = thresh_gate.unsqueeze(1).unsqueeze(-1)

        q_spike = self.q_lif(q_ex_seq, gate=gate_q)  # 注入
        k_spike = self.k_lif(k_wins_seq)
        v_spike = self.v_lif(v_wins_seq)

        attn_logits = (q_spike * k_spike).sum(dim=-2)
        attn_logits = attn_logits.unsqueeze(-2)

        if rpb is not None:
            rpb_ex = rpb.view(1, 1, Heads, 1, 1, 1, -1)
            attn_logits = attn_logits + rpb_ex

        # attn_probs = shift_max(attn_logits, dim=-1)
        # attn_spike = self.attn_lif(attn_probs)
        attn_spike = self.attn_lif(attn_logits)

        out_spike = torch.matmul(attn_spike, v_spike)
        out_integrated = out_spike.sum(dim=1).squeeze(-2)
        out = out_integrated / self.T

        return out

    def forward(self, x, guide_amp=None, guide_phase=None):
        B, C, H, W = x.size()
        dtype, device = x.dtype, x.device

        x_mod = self.ldr(x)
        q = self.proj_q(x_mod)

        # === SGA: Phase-Guided Offset ===
        if guide_phase is not None:
            # 1. 结构图平滑
            phase_clean = self.phase_refine(guide_phase)
            # 2. 拼接 Query 和 Phase
            q_for_offset = torch.cat([q, phase_clean], dim=1)
        else:
            q_for_offset = torch.cat([q, q], dim=1)

        q_off = einops.rearrange(q_for_offset, 'b (g c) h w -> (b g) c h w', g=self.n_groups,
                                 c=self.n_group_channels * 2)
        offset = self.conv_offset(q_off)

        if self.offset_range_factor >= 0 and not self.no_off:
            offset = offset.tanh().mul(self.offset_range_factor)
        offset = einops.rearrange(offset, 'b p h w -> b h w p')
        reference = self._get_ref_points(H, W, B, dtype, device)
        if self.no_off: offset.fill_(0.0)
        pos = (offset + reference).clamp(-1., +1.)

        x_reshaped = x.reshape(B * self.n_groups, self.n_group_channels, H, W)
        x_sampled = F.grid_sample(x_reshaped, pos, mode='bilinear', align_corners=True)
        x_sampled = x_sampled.reshape(B, C, H, W)

        residual_lepe = self.rpe_table(q)

        q = einops.rearrange(q, 'b (h c) x y -> b h x y c', h=self.num_heads)
        k = einops.rearrange(self.proj_k(x_sampled), 'b (h c) x y -> b h x y c', h=self.num_heads)
        v = einops.rearrange(self.proj_v(x_sampled), 'b (h c) x y -> b h x y c', h=self.num_heads)
        q = q * self.scale

        # === IAT: Amplitude-Guided Threshold ===
        thresh_gate = None
        if guide_amp is not None:
            # 1. 归一化 (防数值过大)
            amp_norm = (guide_amp - guide_amp.mean(dim=(2, 3), keepdim=True)) / (
                        guide_amp.std(dim=(2, 3), keepdim=True) + 1e-5)
            # 2. Tanh 映射 (-1, 1)
            delta = self.amp_to_thresh(amp_norm)
            # 3. 缩放系数 0.2
            thresh_gate = delta * 0.2
            # 4. 调整维度匹配 Attention Heads
            thresh_gate = einops.rearrange(thresh_gate, 'b (h c) x y -> b h x y c', h=self.num_heads)

        q1, q2, q3 = q.chunk(3, dim=1)
        k1, k2, k3 = k.chunk(3, dim=1)
        v1, v2, v3 = v.chunk(3, dim=1)

        g1, g2, g3 = (None, None, None)
        if thresh_gate is not None:
            g1, g2, g3 = thresh_gate.chunk(3, dim=1)

        out_h1 = self._spiking_sliding_window_attn(q1, k1, v1, self.kernel_size, self.dilation, self.rpb_h1, g1)
        out_h2 = self._spiking_sliding_window_attn(q2, k2, v2, self.kernel_size, 2, self.rpb_h2, g2)
        out_h3 = self._spiking_sliding_window_attn(q3, k3, v3, self.kernel_size + 2, self.dilation, self.rpb_h3, g3)

        out = torch.cat([out_h1, out_h2, out_h3], dim=1)
        out = einops.rearrange(out, 'b h x y c -> b (h c) x y')
        out = out + residual_lepe
        y = self.proj_drop(self.proj_out(out))
        return y


