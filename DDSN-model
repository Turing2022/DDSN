class LayerNormFunction(torch.autograd.Function):
    @staticmethod
    def forward(ctx, x, weight, bias, eps):
        ctx.eps = eps
        N, C, H, W = x.size()
        mu = x.mean(dim=1, keepdim=True)
        var = x.var(dim=1, keepdim=True, unbiased=False)
        y = (x - mu) / torch.sqrt(var + eps)
        ctx.save_for_backward(y, var, weight)
        y = weight.view(1, C, 1, 1) * y + bias.view(1, C, 1, 1)
        return y

    @staticmethod
    def backward(ctx, grad_output):
        eps = ctx.eps
        y, var, weight = ctx.saved_tensors
        N, C, H, W = grad_output.shape
        g = grad_output * weight.view(1, C, 1, 1)
        mean_g = g.mean(dim=1, keepdim=True)
        mean_gy = (g * y).mean(dim=1, keepdim=True)
        gx = 1. / torch.sqrt(var + eps) * (g - y * mean_gy - mean_g)
        dw = (grad_output * y).sum(dim=(0, 2, 3))
        db = grad_output.sum(dim=(0, 2, 3))
        return gx, dw, db, None


class LayerNorm2d(nn.Module):
    def __init__(self, channels=None, eps=1e-6):
        super().__init__()
        self.channels = channels
        self.eps = eps
        self.weight = None
        self.bias = None

    def forward(self, x):
        if self.weight is None:
            C = x.shape[1] if self.channels is None else self.channels
            self.weight = nn.Parameter(torch.ones(C, device=x.device))
            self.bias = nn.Parameter(torch.zeros(C, device=x.device))
            self.register_parameter('weight', self.weight)
            self.register_parameter('bias', self.bias)
        return LayerNormFunction.apply(x, self.weight, self.bias, self.eps)


