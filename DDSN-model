# 5. FreMLP (升级版: 双重输出)
# ==========================================
class FreMLP(nn.Module):
    def __init__(self, nc, expand=2):
        super(FreMLP, self).__init__()
        self.process1 = nn.Sequential(
            nn.Conv2d(nc, expand * nc, 1, 1, 0),
            nn.LeakyReLU(0.1, inplace=True),
            nn.Conv2d(expand * nc, nc, 1, 1, 0))

    def forward(self, x):
        _, _, H, W = x.shape
        x_freq = torch.fft.rfft2(x, norm='backward')
        mag = torch.abs(x_freq)
        pha = torch.angle(x_freq)

        mag_mod = self.process1(mag)

        # 1. F_amp: 光照增强特征 (用于阈值引导 + 光照恢复)
        real = mag_mod * torch.cos(pha)
        imag = mag_mod * torch.sin(pha)
        x_out = torch.complex(real, imag)
        x_freq_enhanced = torch.fft.irfft2(x_out, s=(H, W), norm='backward')

        # 2. Phase Map: 纯结构特征 (用于几何引导)
        # 强制幅度为 1，只保留相位
        ones = torch.ones_like(mag)
        real_pha = ones * torch.cos(pha)
        imag_pha = ones * torch.sin(pha)
        x_pha_only = torch.complex(real_pha, imag_pha)
        x_phase_struct = torch.fft.irfft2(x_pha_only, s=(H, W), norm='backward')

        return x_freq_enhanced, x_phase_struct


